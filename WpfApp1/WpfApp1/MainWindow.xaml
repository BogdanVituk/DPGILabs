<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="TextEditor" Height="450" Width="800">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"></Setter>
            <Setter Property="Background" Value="Transparent"></Setter>
            <Setter Property="BorderBrush" Value="White"></Setter>
        </Style>

        <LinearGradientBrush x:Key="linearPanelBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="Yellow" Offset="0"></GradientStop>
            <GradientStop Color="Aqua" Offset="0.5"></GradientStop>
            <GradientStop Color="#FFDADA1A" Offset="1"></GradientStop>
        </LinearGradientBrush>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="#FFCBBEBE" BorderThickness="2" CornerRadius="10" Margin="5" Background="{StaticResource linearPanelBrush}">

            <StackPanel  Orientation="Horizontal">
                <Button Width="70" ToolTip="Відкрити..." Command="ApplicationCommands.Open">
                <Image Source="/img/open.png"></Image>
            </Button>
                <Button Width="70" ToolTip="Очистити" Command="ApplicationCommands.Delete">
                <Image Source="/img/tr.png"></Image>
            </Button>
                <Button Width="70" ToolTip="Копіювати" Command="ApplicationCommands.Copy">
                <Image Source="/img/copy.png"></Image>
            </Button>
                <Button Width="70" ToolTip="Вставити" Command="ApplicationCommands.Paste">
                <Image Source="/img/input.png"></Image>
            </Button>
        </StackPanel>
        </Border>
        <Border Grid.Row="1" BorderBrush="#FFCBBEBE" BorderThickness="2" CornerRadius="10" Margin="5" 
                Background="{StaticResource linearPanelBrush}">
            <Grid Grid.Row="1" Name="grid2" >
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                </Grid.RowDefinitions>
                <TextBox Name="textBox1" AcceptsTab="True" Grid.Row="0" Margin="10,10,10,0" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Visible" AcceptsReturn="True" 
                         FontSize="{Binding ElementName=fontSlider, Path=Value, UpdateSourceTrigger=PropertyChanged}"/>


                <DockPanel Grid.Row="1" Name="dock1">
                    <DockPanel>
                        <Label Margin="10,10,10,10">Розмір шрифту:</Label>
                        <Slider Margin="4" MinWidth="100" Maximum="100" Minimum="12" Value="14" Name="fontSlider"/>
                    </DockPanel>
                    <Button Style="{x:Null}" MaxHeight="30" MaxWidth="100" Margin="10,10,10,10" x:Name="button1" Command="ApplicationCommands.Save" DockPanel.Dock="Top">
                        <Label Name="ok">Ok</Label>
                    </Button>
                </DockPanel>
            </Grid>
        </Border>
        
    </Grid>

</Window>